# -----------------------------------------------------------------------------
# Produção (opção B — um domínio; Nginx faz proxy de /api/v1 para o backend)
# Copie para .env.production no build ou use deploy/.env.prod.example no servidor.
# -----------------------------------------------------------------------------

BASEPATH=
NEXT_PUBLIC_APP_URL=https://SEU_DOMINIO
NEXT_PUBLIC_API_BASE_URL=https://SEU_DOMINIO

NEXTAUTH_BASEPATH=${BASEPATH}/api/auth
NEXTAUTH_URL=https://SEU_DOMINIO/api/auth
NEXTAUTH_SECRET=

# Gerar segredo: openssl rand -base64 32
